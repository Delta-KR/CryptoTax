{
  "name": "kontaxt-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "email:dev": "email dev --dir emails --port 3001",
    "email:build": "tsx scripts/build-emails.ts",
    "legal-review:generate": "tsx scripts/generate-legal-review-artifacts.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@react-pdf/renderer": "~4.5.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "next": "^16.2.6",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.4",
    "pretendard": "~1.3.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "tailwind-merge": "^2.5.5",
    "uuid": "^14.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.17.6",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "postcss": "^8.5.10",
    "react-email": "^6.1.5",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.2",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
